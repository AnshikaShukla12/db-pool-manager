# ─────────────────────────────────────────────
#   db-pool-manager — Environment Configuration
#   Copy this file to .env and fill in values
#   cp config/.env.example .env
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=5000
NODE_ENV=development           # development | production | test

# ── Database ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432                   # 5432 for PostgreSQL, 3306 for MySQL
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_DIALECT=postgres            # postgres | mysql | sqlite

# ── Connection Pool Settings ──────────────────
POOL_MIN=2                     # Minimum number of connections
POOL_MAX=10                    # Maximum number of connections
POOL_IDLE_TIMEOUT=30000        # Close idle connections after (ms)
POOL_ACQUIRE_TIMEOUT=60000     # Max time to wait for a connection (ms)
POOL_EVICT_INTERVAL=1000       # How often to check for idle connections (ms)

# ── Authentication ────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100    # Max requests per window per IP

# ── Logging ───────────────────────────────────
LOG_LEVEL=info                 # error | warn | info | debug
LOG_DIR=logs

# ── CORS ──────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────
# ⚠️  NEVER commit the actual .env file to Git!
#     Only commit this .env.example file.
# ─────────────────────────────────────────────
